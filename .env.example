# ============================================================
# Origin Agent Bounty Hunter — Environment Configuration
# ============================================================
# Copy to .env and fill in real values for production mode.
# Default values (empty or commented) enable DEMO MODE.

# ----- Core Mode -----
DEMO_MODE=true          # Set to false to enable real integrations
PORT=3001               # API server port

# ----- Demo Options -----
# DEMO_DISQUALIFY_AGENT=drill   # Force this agent to fail audit (demo disqualification)

# ----- x402 Payment Protocol -----
# Leave empty to use local demo payment adapter
X402_FACILITATOR_URL=   # e.g. https://facilitator.x402.org
# Reference: https://github.com/coinbase/x402

# ----- Coinbase CDP (AgentKit + x402 real mode) -----
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=
# Reference: https://docs.cdp.coinbase.com/agent-kit/getting-started/quickstart

# ----- Base Sepolia (Verdict Contract) -----
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VERDICT_PRIVATE_KEY=    # Private key of verdict publisher wallet (funded on Base Sepolia)
VERDICT_CONTRACT_ADDRESS=  # After: cd packages/contracts && npm run deploy:sepolia
BASESCAN_API_KEY=       # For contract verification (optional)
# Network: eip155:84532 (Base Sepolia)

# ----- AWS -----
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=     # Or use IAM role in production
# AWS_SECRET_ACCESS_KEY= # Or use IAM role in production
BEDROCK_REGION=us-east-1   # For Optimus explanation via Claude

# ----- Storage -----
# Leave empty to use local in-memory storage (demo mode)
DYNAMODB_TABLE_PREFIX=origin-prod-  # Prefix for DynamoDB table names

# ----- Data Provider -----
# The paid data endpoint (x402-gated)
PAID_DATA_SELLER_WALLET=0x0000000000000000000000000000000000000001  # Demo wallet

# ----- Payment Client (Prompt 2) -----
# x402-gated endpoint built in Prompt 1 (CloudFront URL)
PAID_DATA_URL=                   # e.g. https://d123.cloudfront.net/data/defi-protocols
OPTIMUS_DATA_BUDGET_USDC=0.01   # Max USDC per bounty for data fetch
# CDP AgentKit (for real x402 payments on Base Sepolia)
CDP_API_KEY_NAME=                # From Coinbase Developer Platform
CDP_API_KEY_PRIVATE_KEY=         # From CDP
AGENT_WALLET_SEED=               # Export from CDP wallet (keep secret!)
FACILITATOR_URL=https://x402.org/facilitator
DYNAMODB_TABLE=OriginAgentSpend  # DynamoDB table for spend receipts
